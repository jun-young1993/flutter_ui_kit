  "passwordTooWeak": "Password is too weak",
  "@passwordTooWeak": { "description": "Weak password validation error" },

  "passwordRequirements": "Password must contain at least one uppercase letter, one lowercase letter, and one number",
  "@passwordRequirements": { "description": "Password requirements text" },

  "passwordsDoNotMatch": "Passwords do not match",
  "@passwordsDoNotMatch": { "description": "Password mismatch validation error" },

  "invalidInput": "Invalid input",
